# Copy to .env and fill in. NEVER commit .env.

# ============================================================================
# CUSTOM ENGINE AGENT (the bot in Copilot Chat) — src/bot.py + src/agent_core.py
# ============================================================================

# --- Claude via Azure AI Foundry (the agent's brain) ---
# Base URL WITHOUT the /v1/messages suffix (the anthropic SDK appends it).
FOUNDRY_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com
FOUNDRY_API_KEY=<your-foundry-api-key>
# Your Claude deployment name in Foundry (defaults to claude-opus-4-8).
FOUNDRY_MODEL_NAME=claude-opus-4-8

# --- Azure Bot identity (only needed when DEPLOYED / authenticated;
#     NOT needed for local Agents Playground testing, which runs anonymous) ---
clientId=<bot-entra-app-client-id>
clientSecret=<bot-entra-app-client-secret>
tenantId=<your-entra-tenant-id>
# When deployed, bind the server to all interfaces:
# HOST=0.0.0.0

# ============================================================================
# FOUNDRY IQ — grounded, cited rulebook (Gate #2)  —  src/foundry_iq.py
# A Foundry IQ knowledge base backed by Azure AI Search. The bot retrieves the
# real clause/policy text for each finding. Populate with
# scripts/build_rulebook_index.py. See FOUNDRY-IQ-SETUP.md.
# ============================================================================
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<search-admin-or-query-key>
AZURE_SEARCH_INDEX=c2c-rulebook

# ============================================================================
# WORK IQ (live) — emailed human side-commitments  —  src/work_iq.py
# Microsoft Graph (app-only, Mail.Read + admin consent). Live when these are set;
# leave blank to self-disable (the agent then relies on the formal contract only).
# ============================================================================
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
WORK_IQ_MAILBOX=

# ============================================================================
# FABRIC IQ (GATED / OPTIONAL) — structured portfolio analytics  —  src/fabric_iq.py
# Queries a Microsoft Fabric OneLake Lakehouse via its SQL analytics endpoint
# (Entra service-principal auth). Leave blank to keep the gate SHUT — the agent
# then never offers query_portfolio and relies on the reconciler only. Activates
# with no code change once a Fabric capacity + Lakehouse exist.
# Runtime extra (Fabric only): pip install pyodbc + "ODBC Driver 18 for SQL Server".
# ============================================================================
FABRIC_SQL_ENDPOINT=
FABRIC_LAKEHOUSE=
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=

# ============================================================================
# OPTIONAL — pro-code Azure AI Foundry Agent Service path (src/foundry_agent.py)
# Distinct from the bot's Claude client above. Uses DefaultAzureCredential.
# ============================================================================
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o
FOUNDRY_IQ_KNOWLEDGE_BASE_ID=

# ============================================================================
# OPTIONAL — MCP server (src/mcp_server/server.py) OAuth (Microsoft Entra ID)
# ============================================================================
ENTRA_TENANT_ID=
ENTRA_AUDIENCE=
# For local dev only, bypass auth on the MCP server:
DISABLE_AUTH=1
